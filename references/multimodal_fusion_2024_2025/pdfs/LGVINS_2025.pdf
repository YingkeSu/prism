</form>
<script>
    $(function () {
        var searchForm = $("#search-everything");
        var searchField = $(".search-field", searchForm);
        searchForm.on("submit", function () {
            var field = searchField.find("input");
            var searchString = field.val();

            // No enter key submit nothing :-)
            if (!searchString) return false;

            if (searchString.length >= 200) {
                searchForm.attr("method", "post");
                searchForm.attr("action", "/en/concepts/copypaste/");
                field.attr("name", "text");
            }
        });
    });
</script>
